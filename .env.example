# ─────────────────────────────────────────────────────────────────────────────
# UrbanPulse AI — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values that apply to your setup.
# All keys marked OPTIONAL will activate graceful fallbacks when missing.
# The application NEVER crashes or shows error messages for missing optional keys.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════

ENVIRONMENT=development           # development | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# ═══════════════════════════════════════════════════════════════
# DATABASE — TimescaleDB (PostgreSQL)
# Auto-configured when using Docker Compose.
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://urbanpulse_admin:secure_password@localhost:5432/urbanpulse

# ═══════════════════════════════════════════════════════════════
# REDIS — Message Broker & Session Cache
# Auto-configured when using Docker Compose.
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════
# SECURITY
# Generate a secure value: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ═══════════════════════════════════════════════════════════════
# CORS — Add your frontend domain in production
# ═══════════════════════════════════════════════════════════════
CORS_ORIGINS=http://localhost:3000,https://urbanpulse-ai.vercel.app

# ═══════════════════════════════════════════════════════════════
# OPENAI — OPTIONAL
# ───────────────────────────────────────────────────────────────
# When present: Powers the real LangGraph multi-step reasoning agent.
# When absent:  The seeded Intelligence Engine activates automatically.
#               Responses are context-aware and unique — no API calls needed.
#
# Get your key at: https://platform.openai.com/api-keys
# ═══════════════════════════════════════════════════════════════
# OPENAI_API_KEY=sk-...

# ═══════════════════════════════════════════════════════════════
# MAPBOX — OPTIONAL
# ───────────────────────────────────────────────────────────────
# When present: Interactive 3D Mapbox map with satellite imagery.
# When absent:  Premium animated SVG transit network activates automatically.
#               Fully functional with glowing nodes, route animations, tooltips.
#
# Get your free token at: https://account.mapbox.com/
# ═══════════════════════════════════════════════════════════════
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.ey...

# ═══════════════════════════════════════════════════════════════
# FRONTEND — API Endpoints
# ───────────────────────────────────────────────────────────────
# When absent: Frontend operates in standalone mode with in-browser intelligence.
# When present: Frontend connects to your deployed backend services.
# ═══════════════════════════════════════════════════════════════
# NEXT_PUBLIC_CORE_API_URL=https://your-core-api.railway.app
# NEXT_PUBLIC_AGENT_API_URL=https://your-agent-service.railway.app

# ═══════════════════════════════════════════════════════════════
# INTERNAL SERVICE URLS (used inside Docker network)
# ═══════════════════════════════════════════════════════════════
CORE_API_URL=http://core-api:8000/api/v1
AI_INFERENCE_URL=http://ai-inference:8000/api/v1
